{
    "name": "goorm-ide",
    "displayName": "goorm-ide",
    "description": "goorm ide in vscode",
    "version": "1.2.0",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "authentication": [
            {
                "id": "goormIde",
                "label": "구름EDU"
            }
        ],
        "commands": [
            {
                "command": "goorm-ide.firstRun",
                "title": "구름EDU 첫 세팅",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.login",
                "title": "구름EDU로 로그인",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.logout",
                "title": "로그아웃",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.selectLearn",
                "title": "수업 선택",
                "icon": "$(three-bars)",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.showQuiz",
                "title": "퀴즈 선택했을 때",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.runCode",
                "title": "실행",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.submitQuiz",
                "title": "제출",
                "category": "구름EDU"
            },
            {
                "command": "goorm-ide.attendance",
                "title": "출석하기",
                "category": "구름EDU",
                "icon": "$(chevron-right)"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "goorm-ide.firstRun",
                    "when": "false"
                },
                {
                    "command": "goorm-ide.showQuiz",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "goorm-ide.attendance",
                    "when": "view == goormTree",
                    "group": "navigation"
                },
                {
                    "command": "goorm-ide.selectLearn",
                    "when": "view == goormTree",
                    "group": "navigation"
                }
            ],
            "editor/title": [
                {
                    "command": "goorm-ide.runCode",
                    "when": "goorm-ide.isEditingSource",
                    "group": "navigation"
                },
                {
                    "command": "goorm-ide.submitQuiz",
                    "when": "goorm-ide.isEditingSource",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "goormIde",
                    "icon": "resources/barIcon.svg",
                    "title": "구름EDU"
                }
            ]
        },
        "views": {
            "goormIde": [
                {
                    "type": "webview",
                    "id": "goormDesc",
                    "name": "과제 설명",
                    "icon": "resources/fileBars.svg",
                    "when": "goorm-ide.isEditingSource"
                },
                {
                    "id": "goormTree",
                    "name": "과제",
                    "icon": "resources/threeBars.svg"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "goormTree",
                "contents": "구름EDU를 VSCode에서 사용하려면 몇가지 설정을 진행해야해요.\n\n[구름EDU 설정](command:goorm-ide.firstRun)\n\n만약 이미 로그인을 한 적이 있다면, 아래 버튼을 눌러주세요.\n\n[구름EDU 로그인](command:goorm-ide.login)"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.5.0",
        "@types/vscode": "^1.110.0",
        "@types/ws": "^8.18.1",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "axios": "^1.14.0",
        "cheerio": "^1.2.0",
        "cookie": "^1.1.1",
        "vscode-debugadapter": "^1.51.0",
        "vscode-debugprotocol": "^1.51.0",
        "ws": "^8.20.0"
    }
}